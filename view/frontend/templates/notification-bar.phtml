<?php /* === JavaScript — vanilla JS, no dependencies === */ ?>
<script>
(function() {
    'use strict';

    function setCookie(name, value, days) {
        var expires = '';
        if (days > 0) {
            var d = new Date();
            d.setTime(d.getTime() + (days * 86400000));
            expires = '; expires=' + d.toUTCString();
        }
        document.cookie = name + '=' + encodeURIComponent(value) + expires + '; path=/; SameSite=Lax';
    }

    function getCookie(name) {
        var nameEQ = name + '=';
        var ca = document.cookie.split(';');
        for (var i = 0; i < ca.length; i++) {
            var c = ca[i].trim();
            if (c.indexOf(nameEQ) === 0) {
                return decodeURIComponent(c.substring(nameEQ.length));
            }
        }
        return null;
    }

    function dismissBar(bar, cookieDuration, barId) {
        bar.style.transition = 'opacity 0.3s ease, max-height 0.3s ease';
        bar.style.opacity = '0';
        bar.style.maxHeight = '0';
        bar.style.overflow = 'hidden';
        bar.style.padding = '0';
        setTimeout(function() {
            bar.style.display = 'none';
        }, 300);
        if (cookieDuration > 0) {
            setCookie('panth_nbar_' + barId, 'dismissed', cookieDuration);
        } else {
            try {
                sessionStorage.setItem('panth_nbar_' + barId, 'dismissed');
            } catch (e) {}
        }
    }

    function initBars() {
        document.querySelectorAll('.panth-nbar').forEach(function(bar) {
            var barId = bar.dataset.barId;
            var dismissible = bar.dataset.dismissible === '1';
            var cookieDuration = parseInt(bar.dataset.cookieDuration || '7', 10);
            var autoClose = parseInt(bar.dataset.autoClose || '0', 10);
            var animation = bar.dataset.animation || 'slide_down';

            // Check if dismissed via cookie or session
            if (dismissible) {
                if (getCookie('panth_nbar_' + barId) === 'dismissed') {
                    bar.style.display = 'none';
                    return;
                }
                try {
                    if (cookieDuration === 0 && sessionStorage.getItem('panth_nbar_' + barId) === 'dismissed') {
                        bar.style.display = 'none';
                        return;
                    }
                } catch (e) {}
            }

            // Show with animation
            if (animation === 'slide_down') {
                bar.style.transform = 'translateY(-100%)';
                bar.style.transition = 'transform 0.4s ease';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        bar.style.transform = 'translateY(0)';
                    });
                });
            } else if (animation === 'fade_in') {
                bar.style.opacity = '0';
                bar.style.transition = 'opacity 0.5s ease';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        bar.style.opacity = '1';
                    });
                });
            }

            // Close button
            var closeBtn = bar.querySelector('.panth-nbar-close');
            if (closeBtn) {
                closeBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    dismissBar(bar, cookieDuration, barId);
                });
            }

            // CTA with # url acts as dismiss on click
            var ctaBtn = bar.querySelector('.panth-nbar-cta[href="#"]');
            if (ctaBtn && dismissible) {
                ctaBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    dismissBar(bar, cookieDuration, barId);
                });
            }

            // Auto-close
            if (autoClose > 0) {
                setTimeout(function() {
                    dismissBar(bar, dismissible ? cookieDuration : -1, barId);
                }, autoClose * 1000);
            }
        });

        // Countdown timers
        document.querySelectorAll('.panth-nbar-countdown').forEach(function(el) {
            var endDate = new Date(el.dataset.endDate).getTime();
            var expiredText = el.dataset.expiredText || 'Expired';

            function update() {
                var now = new Date().getTime();
                var diff = endDate - now;
                if (diff <= 0) {
                    el.innerHTML = expiredText;
                    return;
                }
                var days = Math.floor(diff / 86400000);
                var hours = Math.floor((diff % 86400000) / 3600000);
                var mins = Math.floor((diff % 3600000) / 60000);
                var secs = Math.floor((diff % 60000) / 1000);

                el.innerHTML = (days > 0 ? '<span class="panth-nbar-cd-unit">' + days + '<small>d</small></span> ' : '')
                    + '<span class="panth-nbar-cd-unit">' + String(hours).padStart(2, '0') + '<small>h</small></span> '
                    + '<span class="panth-nbar-cd-unit">' + String(mins).padStart(2, '0') + '<small>m</small></span> '
                    + '<span class="panth-nbar-cd-unit">' + String(secs).padStart(2, '0') + '<small>s</small></span>';
            }
            update();
            setInterval(update, 1000);
        });
    }

    // Run on DOM ready — works on both Hyva and Luma
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initBars);
    } else {
        initBars();
    }
})();
</script>
