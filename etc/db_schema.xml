<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="panth_notification_bar" resource="default" engine="innodb"
           comment="Panth Notification Bar">

        <!-- Primary Key -->
        <column xsi:type="int" name="bar_id" unsigned="true" nullable="false" identity="true"
                comment="Bar ID"/>

        <!-- Core Fields -->
        <column xsi:type="varchar" name="name" nullable="false" length="255"
                comment="Admin Name"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1"
                comment="Is Active"/>
        <column xsi:type="varchar" name="bar_type" nullable="false" length="20" default="info"
                comment="Bar Type (info, warning, success, promo, urgent, custom)"/>
        <column xsi:type="varchar" name="position" nullable="false" length="20" default="top_fixed"
                comment="Position (top_fixed, top_static, bottom_fixed, bottom_floating)"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0"
                comment="Sort Order"/>
        <column xsi:type="text" name="content" nullable="false"
                comment="Bar Message Content (supports HTML)"/>

        <!-- Appearance -->
        <column xsi:type="varchar" name="background_type" nullable="false" length="20" default="color"
                comment="Background Type (color, gradient, image)"/>
        <column xsi:type="varchar" name="background_color" nullable="false" length="20" default="#1F2937"
                comment="Background Color"/>
        <column xsi:type="varchar" name="background_gradient" nullable="true" length="100"
                comment="Background Gradient CSS"/>
        <column xsi:type="varchar" name="background_image" nullable="true" length="512"
                comment="Background Image Path"/>
        <column xsi:type="varchar" name="text_color" nullable="false" length="20" default="#FFFFFF"
                comment="Text Color"/>
        <column xsi:type="int" name="font_size" unsigned="true" nullable="false" default="14"
                comment="Font Size (px)"/>
        <column xsi:type="int" name="bar_height" unsigned="true" nullable="false" default="0"
                comment="Bar Height (0 = auto)"/>
        <column xsi:type="varchar" name="bar_padding" nullable="false" length="20" default="10px 20px"
                comment="Bar Padding"/>
        <column xsi:type="varchar" name="icon" nullable="true" length="50"
                comment="Icon Name"/>
        <column xsi:type="text" name="custom_css" nullable="true"
                comment="Custom CSS"/>

        <!-- CTA Button -->
        <column xsi:type="smallint" name="cta_enabled" unsigned="true" nullable="false" default="0"
                comment="CTA Enabled"/>
        <column xsi:type="varchar" name="cta_text" nullable="true" length="100"
                comment="CTA Button Text"/>
        <column xsi:type="varchar" name="cta_url" nullable="true" length="512"
                comment="CTA Button URL"/>
        <column xsi:type="smallint" name="cta_open_new_tab" unsigned="true" nullable="false" default="0"
                comment="CTA Open New Tab"/>
        <column xsi:type="varchar" name="cta_bg_color" nullable="false" length="20" default="#FFFFFF"
                comment="CTA Background Color"/>
        <column xsi:type="varchar" name="cta_text_color" nullable="false" length="20" default="#1F2937"
                comment="CTA Text Color"/>

        <!-- Countdown -->
        <column xsi:type="smallint" name="countdown_enabled" unsigned="true" nullable="false" default="0"
                comment="Countdown Enabled"/>
        <column xsi:type="datetime" name="countdown_end_date" nullable="true"
                comment="Countdown End Date"/>
        <column xsi:type="varchar" name="countdown_label" nullable="true" length="100"
                comment="Countdown Label"/>
        <column xsi:type="varchar" name="countdown_expired_text" nullable="true" length="255"
                comment="Countdown Expired Text"/>

        <!-- Dismissal -->
        <column xsi:type="smallint" name="is_dismissible" unsigned="true" nullable="false" default="1"
                comment="Is Dismissible"/>
        <column xsi:type="int" name="cookie_duration" unsigned="true" nullable="false" default="7"
                comment="Cookie Duration (days, 0 = session)"/>

        <!-- Animation -->
        <column xsi:type="varchar" name="animation" nullable="false" length="20" default="slide_down"
                comment="Animation (slide_down, fade_in, none)"/>
        <column xsi:type="int" name="auto_close_seconds" unsigned="true" nullable="false" default="0"
                comment="Auto Close Seconds (0 = never)"/>

        <!-- Scheduling -->
        <column xsi:type="datetime" name="date_from" nullable="true"
                comment="Active From Date"/>
        <column xsi:type="datetime" name="date_to" nullable="true"
                comment="Active To Date"/>

        <!-- Targeting -->
        <column xsi:type="text" name="store_ids" nullable="true"
                comment="Store IDs (comma-separated, 0 = all)"/>
        <column xsi:type="text" name="customer_groups" nullable="true"
                comment="Customer Groups (comma-separated)"/>
        <column xsi:type="varchar" name="page_targeting" nullable="false" length="20" default="all"
                comment="Page Targeting (all, specific, exclude)"/>
        <column xsi:type="text" name="target_urls" nullable="true"
                comment="Target URL Patterns (comma-separated, supports *)"/>
        <column xsi:type="text" name="target_page_types" nullable="true"
                comment="Target Page Types (comma-separated)"/>
        <column xsi:type="text" name="target_countries" nullable="true"
                comment="Target Country Codes (comma-separated)"/>
        <column xsi:type="text" name="target_url_params" nullable="true"
                comment="Target URL Params (key=value pairs)"/>

        <!-- Device Targeting -->
        <column xsi:type="smallint" name="show_on_mobile" unsigned="true" nullable="false" default="1"
                comment="Show On Mobile"/>
        <column xsi:type="smallint" name="show_on_desktop" unsigned="true" nullable="false" default="1"
                comment="Show On Desktop"/>
        <column xsi:type="text" name="mobile_content" nullable="true"
                comment="Mobile Content (optional shorter content)"/>

        <!-- Timestamps -->
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP"
                on_update="true" comment="Updated At"/>

        <!-- Constraints -->
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="bar_id"/>
        </constraint>

        <!-- Indexes -->
        <index referenceId="PANTH_NOTIFICATION_BAR_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
        <index referenceId="PANTH_NOTIFICATION_BAR_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
        <index referenceId="PANTH_NOTIFICATION_BAR_POSITION" indexType="btree">
            <column name="position"/>
        </index>
        <index referenceId="PANTH_NOTIFICATION_BAR_DATE_FROM" indexType="btree">
            <column name="date_from"/>
        </index>
        <index referenceId="PANTH_NOTIFICATION_BAR_DATE_TO" indexType="btree">
            <column name="date_to"/>
        </index>
        <index referenceId="PANTH_NOTIFICATION_BAR_BAR_TYPE" indexType="btree">
            <column name="bar_type"/>
        </index>
    </table>
</schema>
